APP_NAME="Legacy Portal"
APP_ENV=development        # development | production
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://username:password123@localhost:5432/db_namee

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY

PAYSTACK_BASE_URL
PAYSTACK_WEBHOOK_SECRET=

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY

# ─── Check-in Defaults ────────────────────────────────────────────────────────
DEFAULT_CHECKIN_INTERVAL_DAYS
DEFAULT_GRACE_PERIOD_DAYS
ITICK_TOKEN
STOCK_REFRESH_INTERVAL_MINUTES=
